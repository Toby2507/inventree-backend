# ─── Database ────────────────────────────────────────────────────────────────
# POSTGRES_PASSWORD -> Github Secret: CI_POSTGRES_PASSWORD
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventree
DB_USER=inventree
# DB_PASSWORD -> Github Secret: CI_POSTGRES_PASSWORD

# ─── Cache ───────────────────────────────────────────────────────────────────
# REDIS_PASSWORD -> No password needed for CI redis — no --requirepass set on the sidecar
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ─── API ─────────────────────────────────────────────────────────────────────
PORT=8257
NODE_ENV=test

SYSTEM_NAME=InvenTree Systems
API_URL=http://localhost:8257

# JWT_ACCESS_SECRET  → GitHub Secret: CI_JWT_ACCESS_SECRET
JWT_ACCESS_TTL=1d
# JWT_REFRESH_SECRET → GitHub Secret: CI_JWT_REFRESH_SECRET
JWT_REFRESH_TTL=7d
# JWT_UTIL_SECRET    → GitHub Secret: CI_JWT_UTIL_SECRET
JWT_ISSUER=INVENTREE_BACKEND
JWT_AUDIENCE=INVENTREE_CLIENTS