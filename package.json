{
  "name": "inventree-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "db:codegen": "sh scripts/codegen.sh",
    "docker:dev:up": "docker compose -f compose.dev.yml up --build -d",
    "docker:dev:down": "docker compose -f compose.dev.yml down",
    "docker:dev:reset": "docker compose -f compose.dev.yml down -v",
    "docker:prod:up": "docker compose up --build -d",
    "docker:prod:down": "docker compose down",
    "docker:prod:restart": "docker compose restart",
    "migrate:ci": "nest start migrator",
    "migrate:create": "tsx scripts/create-migrations.ts",
    "migrate:run": "docker compose -f compose.dev.yml run --rm migrator",
    "migrate:test": "docker compose -f compose.dev.yml down -v db && docker compose -f compose.dev.yml run --rm migrator",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "prepare": "husky",
    "test": "jest",
    "test:unit": "jest --selectProjects api-unit outbox-processor-unit worker-core-unit intelligence-worker-unit report-worker-unit libs-unit",
    "test:int": "jest --selectProjects api-int outbox-processor-int worker-core-int intelligence-worker-int report-worker-int libs-int libs-migration-int",
    "test:e2e": "jest --selectProjects api-e2e outbox-processor-e2e worker-core-e2e intelligence-worker-e2e report-worker-e2e libs-e2e",
    "test:project": "jest --selectProjects",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.15",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.15",
    "@nestjs/platform-express": "^11.1.15",
    "@nestjs/schedule": "^6.1.1",
    "bullmq": "^5.70.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.3.1",
    "kysely": "^0.28.11",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuidv7": "^1.1.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^9.9.0",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.15",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "kysely-codegen": "^0.20.0",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": "^22.0.0 || ^24.0.0",
    "pnpm": ">=9.0.0"
  }
}
