{
  "name": "inventree-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "db:codegen:operational": "kysely-codegen --url $DATABASE_URL --schema operational --out-file libs/database/src/operational.types.ts",
    "db:codegen:analytics": "kysely-codegen --url $ANALYTICS_DATABASE_URL --schema analytics --out-file libs/database/src/analytics.types.ts",
    "db:codegen": "pnpm db:codegen:operational && pnpm db:codegen:analytics",
    "docker:dev:up": "docker compose -f compose.dev.yml up --build",
    "docker:dev:down": "docker compose -f compose.dev.yml down",
    "docker:dev:reset": "docker compose -f compose.dev.yml down -v",
    "docker:prod:up": "docker compose up --build -d",
    "docker:prod:down": "docker compose down",
    "docker:prod:restart": "docker compose restart",
    "migrate:ci": "nest start migrator",
    "migrate:create": "tsx scripts/create-migrations.ts",
    "migrate:run": "docker compose -f compose.dev.yml run --rm migrator",
    "migrate:test": "docker compose -f compose.dev.yml down -v db && docker compose -f compose.dev.yml run --rm migrator",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "test": "jest",
    "test:unit": "jest --testMatch=\"**/src/**/*.spec.ts\"",
    "test:integration": "jest --testMatch=\"**/test/integration/**/*.int.spec.ts\"",
    "test:e2e": "jest --testMatch=\"**/test/e2e/**/*.e2e.spec.ts\"",
    "test:unit:project": "pnpm test:unit --selectProjects",
    "test:integration:project": "pnpm test:integration --selectProjects",
    "test:e2e:project": "pnpm test:e2e --selectProjects",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.15",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.15",
    "@nestjs/platform-express": "^11.1.15",
    "@nestjs/schedule": "^6.1.1",
    "bullmq": "^5.70.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "kysely": "^0.28.11",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuidv7": "^1.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.15",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "kysely-codegen": "^0.20.0",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": "^22.0.0 || ^24.0.0",
    "pnpm": ">=9.0.0"
  }
}