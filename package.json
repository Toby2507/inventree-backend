    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-node": "^30.4.1",
    "kysely-codegen": "^0.20.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
