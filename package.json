{
  "name": "inventree-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build:api": "nest build api",
    "build:outbox": "nest build outbox-processor",
    "build:worker-core": "nest build worker-core",
    "build:intelligence-worker": "nest build intelligence-worker",
    "build:report-worker": "nest build report-worker",
    "build:all": "nest build api && nest build outbox-processor && nest build worker-core && nest build intelligence-worker && nest build report-worker",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start:dev:api": "nest start api --watch",
    "start:dev:outbox": "nest start outbox-processor --watch",
    "start:dev:worker-core": "nest start worker-core --watch",
    "start:dev:intelligence-worker": "nest start intelligence-worker --watch",
    "start:dev:report-worker": "nest start report-worker --watch",
    "start:prod:api": "node dist/apps/api/main",
    "start:prod:outbox": "node dist/apps/outbox-processor/main",
    "start:prod:worker-core": "node dist/apps/worker-core/main",
    "start:prod:intelligence-worker": "node dist/apps/intelligence-worker/main",
    "start:prod:report-worker": "node dist/apps/report-worker/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.15",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.15",
    "@nestjs/platform-express": "^11.1.15",
    "@nestjs/schedule": "^6.1.1",
    "bullmq": "^5.70.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "kysely": "^0.28.11",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuidv7": "^1.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.15",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.2.0",
    "kysely-codegen": "^0.20.0",
    "prettier": "^3.8.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.30.3",
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}