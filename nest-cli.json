{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/api/src",
  "monorepo": true,
  "root": "apps/api",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": false,
    "tsConfigPath": "apps/api/tsconfig.app.json"
  },
  "projects": {
    "api": {
      "type": "application",
      "root": "apps/api",
      "entryFile": "main",
      "sourceRoot": "apps/api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api/tsconfig.app.json"
      }
    },
    "outbox-processor": {
      "type": "application",
      "root": "apps/outbox-processor",
      "entryFile": "main",
      "sourceRoot": "apps/outbox-processor/src",
      "compilerOptions": {
        "tsConfigPath": "apps/outbox-processor/tsconfig.app.json"
      }
    },
    "worker-core": {
      "type": "application",
      "root": "apps/worker-core",
      "entryFile": "main",
      "sourceRoot": "apps/worker-core/src",
      "compilerOptions": {
        "tsConfigPath": "apps/worker-core/tsconfig.app.json"
      }
    },
    "worker-intelligence": {
      "type": "application",
      "root": "apps/worker-intelligence",
      "entryFile": "main",
      "sourceRoot": "apps/worker-intelligence/src",
      "compilerOptions": {
        "tsConfigPath": "apps/worker-intelligence/tsconfig.app.json"
      }
    },
    "report-worker": {
      "type": "application",
      "root": "apps/report-worker",
      "entryFile": "main",
      "sourceRoot": "apps/report-worker/src",
      "compilerOptions": {
        "tsConfigPath": "apps/report-worker/tsconfig.app.json"
      }
    },
    "database": {
      "type": "library",
      "root": "libs/database",
      "entryFile": "index",
      "sourceRoot": "libs/database/src",
      "compilerOptions": {
        "tsConfigPath": "libs/database/tsconfig.lib.json"
      }
    },
    "domain": {
      "type": "library",
      "root": "libs/domain",
      "entryFile": "index",
      "sourceRoot": "libs/domain/src",
      "compilerOptions": {
        "tsConfigPath": "libs/domain/tsconfig.lib.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    }
  }
}