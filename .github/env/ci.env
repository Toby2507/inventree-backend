# ─── Database ────────────────────────────────────────────────────────────────
# POSTGRES_PASSWORD -> Github Secret: CI_POSTGRES_PASSWORD
DB_HOST=localhost
DB_PORT=5432
DB_NAME=inventree
DB_USER=inventree
# DB_PASSWORD -> Github Secret: CI_POSTGRES_PASSWORD

# Analytics — same host initially, separate when you split instances
ANALYTICS_DB_HOST=localhost
ANALYTICS_DB_PORT=5432
ANALYTICS_DB_NAME=inventree
ANALYTICS_DB_USER=inventree
# ANALYTICS_DB_PASSWORD -> Github Secret: CI_POSTGRES_PASSWORD

# ─── Cache ───────────────────────────────────────────────────────────────────
# REDIS_PASSWORD -> No password needed for CI redis — no --requirepass set on the sidecar
REDIS_URL=redis://localhost:6379

# ─── API ─────────────────────────────────────────────────────────────────────
PORT=8257
NODE_ENV=test

# JWT_ACCESS_SECRET  → GitHub Secret: CI_JWT_ACCESS_SECRET
JWT_ACCESS_TTL=1d
# JWT_REFRESH_SECRET → GitHub Secret: CI_JWT_REFRESH_SECRET
JWT_REFRESH_TTL=7d
# JWT_UTIL_SECRET    → GitHub Secret: CI_JWT_UTIL_SECRET
JWT_ISSUER=INVENTREE_BACKEND
JWT_AUDIENCE=INVENTREE_CLIENTS

# ─── Outbox Processor ────────────────────────────────────────────────────────
OUTBOX_POLL_INTERVAL_MS=2000
OUTBOX_BATCH_SIZE=50
OUTBOX_LOCK_TTL_SECONDS=30

# ─── Intelligence Worker ──────────────────────────────────────────────────────
TREND_COMPUTATION_CRON=0 */4 * * *
RECOMMENDATION_CRON=0 2 * * *