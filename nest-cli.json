{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/api/src",
  "monorepo": true,
  "root": "apps/api",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": false,
    "tsConfigPath": "apps/api/tsconfig.app.json"
  },
  "projects": {
    "api": {
      "type": "application",
      "root": "apps/api",
      "entryFile": "main",
      "sourceRoot": "apps/api/src",
      "compilerOptions": {
        "tsConfigPath": "apps/api/tsconfig.app.json"
      }
    },
    "intelligence-worker": {
      "type": "application",
      "root": "apps/intelligence-worker",
      "entryFile": "main",
      "sourceRoot": "apps/intelligence-worker/src",
      "compilerOptions": {
        "tsConfigPath": "apps/intelligence-worker/tsconfig.app.json"
      }
    },
    "migrator": {
      "type": "application",
      "root": "apps/migrator",
      "entryFile": "main",
      "sourceRoot": "apps/migrator/src",
      "compilerOptions": {
        "tsConfigPath": "apps/migrator/tsconfig.app.json"
      }
    },
    "outbox-processor": {
      "type": "application",
      "root": "apps/outbox-processor",
      "entryFile": "main",
      "sourceRoot": "apps/outbox-processor/src",
      "compilerOptions": {
        "tsConfigPath": "apps/outbox-processor/tsconfig.app.json"
      }
    },
    "report-worker": {
      "type": "application",
      "root": "apps/report-worker",
      "entryFile": "main",
      "sourceRoot": "apps/report-worker/src",
      "compilerOptions": {
        "tsConfigPath": "apps/report-worker/tsconfig.app.json"
      }
    },
    "worker-core": {
      "type": "application",
      "root": "apps/worker-core",
      "entryFile": "main",
      "sourceRoot": "apps/worker-core/src",
      "compilerOptions": {
        "tsConfigPath": "apps/worker-core/tsconfig.app.json"
      }
    },
    "common": {
      "type": "library",
      "root": "libs/common",
      "entryFile": "index",
      "sourceRoot": "libs/common/src",
      "compilerOptions": {
        "tsConfigPath": "libs/common/tsconfig.lib.json"
      }
    },
    "config": {
      "type": "library",
      "root": "libs/config",
      "entryFile": "index",
      "sourceRoot": "libs/config/src",
      "compilerOptions": {
        "tsConfigPath": "libs/config/tsconfig.lib.json"
      }
    },
    "contexts": {
      "type": "library",
      "root": "libs/contexts",
      "entryFile": "index",
      "sourceRoot": "libs/contexts/src",
      "compilerOptions": {
        "tsConfigPath": "libs/contexts/tsconfig.lib.json"
      }
    },
    "core": {
      "type": "library",
      "root": "libs/core",
      "entryFile": "index",
      "sourceRoot": "libs/core/src",
      "compilerOptions": {
        "tsConfigPath": "libs/core/tsconfig.lib.json"
      }
    },
    "database": {
      "type": "library",
      "root": "libs/database",
      "entryFile": "index",
      "sourceRoot": "libs/database/src",
      "compilerOptions": {
        "tsConfigPath": "libs/database/tsconfig.lib.json"
      }
    },
    "testing": {
      "type": "library",
      "root": "libs/testing",
      "entryFile": "index",
      "sourceRoot": "libs/testing/src",
      "compilerOptions": {
        "tsConfigPath": "libs/testing/tsconfig.lib.json"
      }
    }
  }
}