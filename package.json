{
  "name": "inventree-backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "db:codegen": "sh scripts/codegen.sh",
    "docker:up": "pnpm run \"/^docker:(obs|dev):up$/\"",
    "docker:down": "pnpm docker:dev:down ; pnpm docker:obs:down",
    "docker:dev:build": "docker compose -f compose.dev.yaml up --build -d -V",
    "docker:dev:up": "docker compose -f compose.dev.yaml up -d",
    "docker:dev:down": "docker compose -f compose.dev.yaml down",
    "docker:dev:reset": "docker compose -f compose.dev.yaml down -v",
    "docker:obs:up": "docker compose -f compose.obs.yaml up -d",
    "docker:obs:down": "docker compose -f compose.obs.yaml down",
    "docker:obs:reset": "docker compose -f compose.obs.yaml down -v",
    "docker:prod:up": "docker compose up --build -d",
    "docker:prod:down": "docker compose down",
    "docker:prod:restart": "docker compose restart",
    "migrate:ci": "nest start migrator",
    "migrate:create": "tsx scripts/create-migrations.ts",
    "migrate:run": "docker compose -f compose.dev.yaml run --rm migrator",
    "migrate:restart": "pnpm docker:dev:reset && pnpm migrate:run",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "prepare": "husky",
    "test": "jest",
    "test:unit": "jest --selectProjects api-unit outbox-processor-unit worker-core-unit intelligence-worker-unit report-worker-unit libs-unit",
    "test:int": "jest --selectProjects api-int outbox-processor-int worker-core-int intelligence-worker-int report-worker-int libs-int libs-migration-int",
    "test:e2e": "jest --selectProjects api-e2e outbox-processor-e2e worker-core-e2e intelligence-worker-e2e report-worker-e2e libs-e2e",
    "test:project": "jest --selectProjects",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@appsignal/opentelemetry-instrumentation-bullmq": "^0.8.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.15",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.15",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.15",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@opentelemetry/api": "^1.9.1",
