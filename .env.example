# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-in-production
DATABASE_URL=postgres://inventree:$POSTGRES_PASSWORD@db:5432/inventree

# ─── Cache ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-in-production
REDIS_URL=redis://:$REDIS_PASSWORD@cache:6379

# ─── API ─────────────────────────────────────────────────────────────────────
PORT=8257
NODE_ENV=development

JWT_ACCESS_SECRET=change-in-production
JWT_ACCESS_TTL=1d
JWT_REFRESH_SECRET=change-in-production
JWT_REFRESH_TTL=7d
JWT_UTIL_SECRET=change-in-production
JWT_ISSUER="INVENTREE_BACKEND"
JWT_AUDIENCE="INVENTREE_CLIENTS"

# ─── Outbox Processor ────────────────────────────────────────────────────────
OUTBOX_POLL_INTERVAL_MS=2000
OUTBOX_BATCH_SIZE=50
OUTBOX_LOCK_TTL_SECONDS=30

# ─── Intelligence Worker ──────────────────────────────────────────────────────
TREND_COMPUTATION_CRON=0 */4 * * *
RECOMMENDATION_CRON=0 2 * * *