# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-in-production
DB_HOST=db
DB_PORT=5432
DB_NAME=inventree
DB_USER=inventree
DB_PASSWORD=$POSTGRES_PASSWORD

# Analytics — same host initially, separate when you split instances
ANALYTICS_DB_HOST=db
ANALYTICS_DB_PORT=5432
ANALYTICS_DB_NAME=inventree
ANALYTICS_DB_USER=inventree
ANALYTICS_DB_PASSWORD=$POSTGRES_PASSWORD

# ─── Cache ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-in-production
REDIS_URL=redis://:$REDIS_PASSWORD@cache:6379

# ─── API ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8257

SYSTEM_NAME=InvenTree Systems
API_URL=http://localhost:8257

JWT_ACCESS_SECRET=change-in-production
JWT_ACCESS_TTL=1d
JWT_REFRESH_SECRET=change-in-production
JWT_REFRESH_TTL=7d
JWT_UTIL_SECRET=change-in-production
JWT_ISSUER="INVENTREE_BACKEND"
JWT_AUDIENCE="INVENTREE_CLIENTS"